# Copy to .env and adjust as needed:
#   cp .env.example .env
#
# Docker Compose loads .env automatically from the project root.

# --- Image ---
# Pre-built image (recommended for quick start):
WEBUI_IMAGE=ekkoye8888/hermes-web-ui
# Local build tag when building from source (comment WEBUI_IMAGE above):
# WEBUI_IMAGE=hermes-web-ui-local:latest

# Base image for `docker compose build` only (Dockerfile ARG BASE_IMAGE)
HERMES_AGENT_IMAGE=nousresearch/hermes-agent:latest
HERMES_AGENT_CONTAINER_NAME=hermes-agent

WEBUI_CONTAINER_NAME=hermes-webui

# --- Ports (host:container) ---
PORT=6060
PREVIEW_FRONTEND_PORT=8651
XAI_OAUTH_PORT=56121
HERMES_GATEWAY_PORT=8642
HERMES_BRIDGE_PORT=18765
HERMES_BRIDGE_CONTAINER_NAME=hermes-bridge

# --- Runtime ---
BIND_HOST=0.0.0.0
HERMES_BIN=/opt/hermes/.venv/bin/hermes
# Compose service name for the external Hermes gateway (hermes-agent container).
GATEWAY_HOST=hermes-agent
# Generate with: openssl rand -hex 32
API_SERVER_ENABLED=true
API_SERVER_KEY=changeme-set-a-strong-key
API_SERVER_CORS_ORIGINS=*

# --- Data ---
HERMES_DATA_DIR=./hermes_data
# Presales profile content (PPT/knowledge/drafts). Host path → container:
#   /home/agent/.hermes/profiles/{HERMES_PROFILE_NAME}/content/
HERMES_PROFILE_NAME=jingdigital
HERMES_PROFILE_CONTENT_DIR=./hermes_data/profiles/jingdigital/content

# --- PostgreSQL (presales knowledge base) ---
PG_CONTAINER_NAME=hermes-pg
POSTGRES_USER=aipresales
POSTGRES_PASSWORD=aipresales
POSTGRES_DB=aipresales
POSTGRES_PORT=5432
PG_DATA_DIR=./pg_data
DATABASE_URL=postgresql://aipresales:aipresales@postgres:5432/aipresales

# --- Redis (presales knowledge ingest queue) ---
REDIS_CONTAINER_NAME=hermes-redis
REDIS_PORT=6380
REDIS_DATA_DIR=./redis_data
REDIS_URL=redis://redis:6379
PRESALES_WORKER_CONTAINER_NAME=hermes-presales-worker
PRESALES_WORKER_CONCURRENCY=1
# Agent bridge runs in `hermes-bridge`; webui/worker attach via compose network.
# Local `npm run dev`: start compose (hermes-agent + hermes-bridge + postgres + redis), then dev server uses 127.0.0.1:18765 / :8642.

# --- UI visibility (Vite build-time; rebuild image after changes) ---
VITE_HERMES_HIDE_SIDEBAR_GROUPS=monitoring,tools
VITE_HERMES_HIDE_SIDEBAR_ITEMS=groupChat,apiRelay
VITE_HERMES_HIDE_GITHUB=1
VITE_HERMES_HIDE_WEBSITE=1
VITE_HERMES_HIDE_STUDIO_VERSION=1

# --- Branding ---
VITE_HERMES_PRODUCT_NAME=aipresales
HERMES_OPENROUTER_APP_TITLE=aipresales
VITE_HERMES_PRESALES_MODE=1
